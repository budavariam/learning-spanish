{
  "name": "learning-spanish",
  "version": "0.2.0",
  "description": "My journey on learning spanish",
  "scripts": {
    "build:ts": "esbuild src/webcomponent-practice.ts --bundle --format=iife --target=es2019 --outfile=js/webcomponent-practice.js",
    "build": "npm run build:ts && env NODE_ENV=production npx @11ty/eleventy",
    "bench": "DEBUG=Eleventy:Benchmark* npx @11ty/eleventy",
    "watch": "npm run build:ts && npx @11ty/eleventy --watch",
    "serve": "npm run build:ts && npx @11ty/eleventy --serve",
    "start": "npm run build:ts && npx @11ty/eleventy --serve",
    "debug": "DEBUG=* npx @11ty/eleventy",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/11ty/eleventy-base-blog.git"
  },
  "author": {
    "name": "Zach Leatherman",
    "email": "zachleatherman@gmail.com",
    "url": "https://zachleat.com/"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "bugs": {
    "url": "https://github.com/11ty/eleventy-base-blog/issues"
  },
  "homepage": "https://github.com/11ty/eleventy-base-blog#readme",
  "dependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@11ty/eleventy-navigation": "^0.3.5",
    "@11ty/eleventy-plugin-rss": "^1.2.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^4.2.0",
    "child_process": "^1.0.2",
    "csv-parse": "^6.1.0",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "terser": "^5.46.0",
    "webcomponent-crossword": "^0.0.18",
    "webcomponent-flashcard": "^0.0.16",
    "webcomponent-word-matcher": "0.0.9",
    "webcomponent-wordlist": "0.0.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "chalk": "^4.1.2",
    "eleventy-plugin-workbox": "^1.4.0",
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "pagefind": "^1.4.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "workbox-build": "^6.6.0"
  }
